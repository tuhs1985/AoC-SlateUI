<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<!-- $Change: 554999 $ (must be within the first 200 characters of the file) -->

<View view_layout="horizontal" h_alignment="RIGHT">

	<View xmlns:template="template.dtd" 
		  xmlns:nocreate="nocreate.dtd" 
		  view_layout="stacked" 
		  v_alignment="BOTTOM" 
		  _view_flags="WID_HANDLE_MOUSE" 
		  layout_borders="Rect(0,0,0,0)">
		  
		<template:ShortcutView out_of_range_bitmap="icons/outofrange_icon.tga" 
							   icon_spacing= "3" 
							   slot_template="SlotTemplate">
			<template:ItemSlotView template:name="SlotTemplate" 
								   layout_borders="Rect(0,0,0,0)" 
								   slot_size= "Point(37,37)" 
								   icon_borders= "Point(0,0)" 
								   max_zoom="0" 
								   gfx_background=""/>
		</template:ShortcutView>
		<template:PerkView  icon_spacing= "3" 
							slot_template="PerkTemplate">
			<template:ItemSlotView template:name="PerkTemplate" 
								   layout_borders="Rect(0,0,0,0)" 
								   slot_size= "Point(37,37)" 
								   icon_borders= "Point(0,0)" 
								   max_zoom="0" 
								   gfx_background=""/>
		</template:PerkView>
		<View view_layout="horizontal" v_alignment="BOTTOM" layout_borders="Rect(0,0,0,53">
			<BitmapView bitmap_gfx=""/>            
		</View>
		<View view_layout="horizontal" v_alignment="BOTTOM" layout_borders="Rect(0,0,0,53)">
	<!-- ********** LEFT SIDE ********** -->
			<View view_layout="vertical" layout_borders="Rect(0,0,0,0)">
				<View name="LPortraitParentView" view_layout="horizontal" v_alignment="BOTTOM" layout_borders="Rect(0,0,-11,0)">
					<HLayoutSpacer/>
					<View name="LPortraitViewDock" view_layout="horizontal" h_alignment="RIGHT" v_alignment="BOTTOM" _min_size_limit="Point(-1,COORD_MAX)" _max_size_extend="Point(COORD_MAX,-1)" layout_borders="Rect(0,0,0,0)">								
					</View>
				</View>

			<!-- === UPPER LEFT === -->

				<View view_layout="stacked" h_alignment="RIGHT" v_alignment="BOTTOM">
					<View view_layout="horizontal">
						<ShortcutView name="sr_upper_left_plus"  layout_borders="Rect(110,0,0,2)" first_slot="200000" slot_count="4" />
						<ViewSelector name="ViewSelector">
							<ShortcutView name="sr_upper_left_first"  layout_borders="Rect(3,0,0,2)" first_slot="10000" slot_count="6" hotkeyrange_start="Shortcutbar_Left_1" hotkeyrange_length="6" />
							<PerkView name="PerkBar1" layout_borders="Rect(3,0,0,2)"  first_slot="13000" slot_count="6" />
						</ViewSelector>
						<ShortcutView name="sr_upper_left_second" layout_borders="Rect(3,0,0,2)" first_slot="20000" slot_count="1" hotkeyrange_start="Shortcutbar_Extra1_1" hotkeyrange_length="1" />

					</View>
				</View>
			<!-- === MIDDLE LEFT === -->
				<View view_layout="stacked" h_alignment="RIGHT" v_alignment="BOTTOM">
					<View view_layout="horizontal">
						<ShortcutView name="sr_middle_left_plus" layout_borders="Rect(110,0,0,2)" first_slot="200004" slot_count="4"/>
						<ShortcutView name="sr_middle_left" layout_borders="Rect(3,0,0,2)" first_slot="20001" slot_count="7" hotkeyrange_start="Shortcutbar_Extra1_2" hotkeyrange_length="7"/>
					</View>
				</View>

			<!-- === BOTTOM LEFT === -->
				<View view_layout="stacked" h_alignment="RIGHT" v_alignment="BOTTOM">
					<View view_layout="horizontal">
						<ShortcutView name="sr_lower_left_plus"  layout_borders="Rect(110,0,0,2)" first_slot="200008" slot_count="4"/>
						<ShortcutView name="sr_lower_left" layout_borders="Rect(3,0,0,2)"  first_slot="20008" slot_count="7" hotkeyrange_start="Shortcutbar_Extra1_9" hotkeyrange_length="7"/>
					</View>
				</View>
			</View>

	<!-- ********** CENTER ********** -->
			<View view_layout="vertical" layout_borders="Rect(-118,0,-119,0)">
				<View name="CombatRoseDock" view_flags="WID_IGNORE_WHEN_HIDDEN" view_layout="stacked" layout_borders="Rect(0,0,0,0)"/>
				<ActionListView name="ActionListView" icon_spacing="-8" default_action_bg="icons/actions/actionicon_selection.tga"/>
		<!-- === LAG METER & PERK BUTTON=== -->
				<View view_layout="stacked" layout_borders="Rect(0,0,0,-3)">
				<BitmapView name="LagIndicator" 
							view_flags="WID_AUTO_HIGHLIGHT"  
							layout_borders="Rect(30,20,3,1)" 
							view_alpha="0.8">
							<nocreate:Bitmap name="../../Customized/gfx/bottombars/lag1.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/bottombars/lag2.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/bottombars/lag3.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/bottombars/lag4.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/bottombars/lag5.png"/>			
				</BitmapView>	
							
					<Button name="PerkBarSwitchButton"
							view_tooltip_text="&lt;localized token=TogglePerkbar /&gt;"
							layout_borders="Rect(0,12,105,0)"
							gfxid_raised    = "../../Customized/gfx/bottombars/perkbtn.png"
							gfxid_pressed   = "../../Customized/gfx/bottombars/perkbtn_on.png"
							gfxid_highlight = "../../Customized/gfx/bottombars/perkbtn_hover.png"
						/>
				</View>

		<!-- === UPPER CENTER === -->
				<View view_layout="horizontal">
					<!-- "sr_upper_center" named "MultiBar1" for default UI consistency -->
					<ShortcutView name="MultiBar1" layout_borders="Rect(0,0,0,2)" first_slot="0" slot_count="3" hotkeyrange_start="Shortcutbar_1" hotkeyrange_length="3"/>
				</View>
		<!-- === MIDDLE CENTER === -->
				<View view_layout="horizontal">
					<!-- "sr_middle_center" named "MultiBar3" for default UI consistency -->
					<ShortcutView name="MultiBar3" layout_borders="Rect(120,0,120,2)" first_slot="10" slot_count="3" hotkeyrange_start="Shortcutbar_11" hotkeyrange_length="3"/>
				</View>
		<!-- === LOWER CENTER === -->
				<View view_layout="horizontal">
					<ShortcutView name="sr_lower_center" layout_borders="Rect(0,0,0,2)" first_slot="20015" slot_count="3" hotkeyrange_start="Shortcutbar_Extra1_16" hotkeyrange_length="3"/>
				</View>
			</View>
	<!-- ********** RIGHT SIDE ********** -->
			<View view_layout="vertical">
				<View name="RPortraitParentView" view_layout="stacked" v_alignment="BOTTOM" layout_borders="Rect(0,0,15,0)">
					<View name="RPortraitViewDock" view_layout="stacked" h_alignment="LEFT" _min_size_limit="Point(-1,COORD_MAX)" _max_size_extend="Point(COORD_MAX,-1)"/>
				</View>
		<!-- === UPPER RIGHT === -->
				<View view_layout="stacked" h_alignment="LEFT" v_alignment="BOTTOM">
					<View view_layout="horizontal">
						<!-- "sr_upper_right_first" named "MultiBar2" for default UI consistency -->
						<ShortcutView name="MultiBar2" layout_borders="Rect(0,0,0,2)" first_slot="3" slot_count="7" hotkeyrange_start="Shortcutbar_4" hotkeyrange_length="7"/>
						<ShortcutView name="sr_upper_right_second" layout_borders="Rect(3,0,110,2)" first_slot="200012" slot_count="4" />
					</View>
				</View>
		<!-- === MIDDLE RIGHT === -->
				<View view_layout="stacked" h_alignment="LEFT" v_alignment="BOTTOM">
					<View view_layout="horizontal">
						<ShortcutView name="sr_middle_right" layout_borders="Rect(0,0,0,2)" first_slot="20100" slot_count="7" hotkeyrange_start="Shortcutbar_Extra2_1" hotkeyrange_length="7"/>
						<ShortcutView name="sr_middle_right_second" layout_borders="Rect(3,0,110,2)" first_slot="200016" slot_count="4"/>
					</View>
				</View>
		<!-- === BOTTOM RIGHT === -->
				<View view_layout="stacked" h_alignment="LEFT" v_alignment="BOTTOM">
					<View view_layout="horizontal">
						<ShortcutView name="ShortcutView" layout_borders="Rect(0,0,0,2)" first_slot="20107" slot_count="7" hotkeyrange_start="Shortcutbar_Extra2_8" hotkeyrange_length="7"/>
						<ShortcutView name="sr_lower_right_second" layout_borders="Rect(3,0,110,2)" first_slot="200020" slot_count="4"/>
					</View>
				</View>
			</View>
		</View>
	</View>
</View>
