<View xmlns:template="template.dtd" view_layout="stacked" view_flags="WID_HANDLE_MOUSE">
	<template:ShortcutView layout_borders="Rect(0,0,0,0)"
		out_of_range_bitmap="icons/outofrange_icon.tga"
		slot_template="SlotTemplate">
		<template:ItemSlotView template:name="SlotTemplate"
			layout_borders="Rect(2,0,2,0)"
			slot_size    = "Point(37,37)"
			icon_borders = "Point(1,1)"
			max_zoom="1.0"
			gfx_background=""
		/>
	</template:ShortcutView>	
	<View name="BgView" view_layout="vertical">
		<BitmapView bitmap_gfx="bottombars/ASB/asb_top.tga"/>
		<BitmapView bitmap_gfx="bottombars/ASB/asb_vertical_background.tga" max_size_extend="Point(-1.0,COORD_MAX)"/>
		<BitmapView name="ResizeKnob" bitmap_gfx="bottombars/ASB/asb_bottom.tga" view_flags="WID_HANDLE_MOUSE" />
	</View>
	<View min_size_limit="Point(COORD_MAX,51)" view_layout="vertical" v_alignment="EXTEND" layout_borders="Rect(0,13,0,13)">
		<ShortcutView name="ShortcutView"
			view_flags = "SBF_VERTICAL|SBF_HIDE_EMPTY_SLOTS"
			view_layout="vertical"		      
			clip_icons="true"
			icon_spacing = "-1"
			slot_bg_gfx="bottombars/ASB/asb_slot.tga"
			first_slot="20020"
			slot_count="40" 
			hotkeyrange_start="Shortcutbar_Extra1_1"
		/>
	</View>
</View>
