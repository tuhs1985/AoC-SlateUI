<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<!-- $Change: 392055 $ (must be within the first 200 characters of the file) -->
<!-- Strange UI 2015 -->
<View xmlns:template = "template.dtd"
	name           = "left_portrait"
	view_layout    = "stacked"
	h_alignment    = "LEFT">
	<template:ProgressBar template:name = "ManaBarShort"
		bg_gfx        = "../../Customized/gfx/frames/p_manabgnew2.png"
		fg_gfx        = "../../Customized/gfx/frames/p_mananew.png"
	/>
	<template:ProgressBar template:name = "ManaBarLong"
		bg_gfx        = "../../Customized/gfx/frames/p_healthbgnew.png"
		fg_gfx        = "../../Customized/gfx/frames/p_mana_bignew.png"
	/>
	<template:ProgressBar template:name = "StaminaBarShort"
		bg_gfx        = "../../Customized/gfx/frames/p_manabgnew.png"
		fg_gfx        = "../../Customized/gfx/frames/p_staminanew.png"
	/>
	<template:ProgressBar template:name = "StaminaBarLong"
		bg_gfx        = "../../Customized/gfx/frames/p_healthbgnew.png"
		fg_gfx        = "../../Customized/gfx/frames/p_stamina_bignew.png"
	/>





	<View view_layout="horizontal">

		<View view_layout="vertical" h_alignment="CENTER" v_alignment="BOTTOM">
			<View view_layout="vertical" h_local_alignment="RIGHT">


		<BuffListView name              = "BuffListView"
					h_local_alignment = "RIGHT"
					icon_size         = "Point(31,31)"
					icon_spacing      = "Point(1,1)"
					full_size_limit   = "14"
					max_columns       = "7"
					layout_borders  = "Rect(0,0,185,5)"
					filter            = "friendly | hostile"
				/>

			</View>

				<View view_layout="horizontal" h_local_alignment="RIGHT" layout_borders = "Rect(0,0,175,0)" >
						<BitmapView name       = "SkullLeft"
							bitmap_gfx = "PortraitGUI/little_skull.tga"
							view_flags = "WID_IGNORE_WHEN_HIDDEN"
							
						/>
						<TextView name           = "LevelView"
							view_flags     = "WID_IGNORE_WHEN_HIDDEN"
							feature_flags  = "TVF_RENDER_HALO|TVF_RENDER_SHADOW|TVF_ENABLE_SHADOW"
							view_alpha="0"
							default_color  = "active"
							font           = "small"
							layout_borders = "Rect(0,0,-24,0)"
						/>

						
						<TextView name           = "NameView"
							view_flags     = "WID_IGNORE_WHEN_HIDDEN"
							max_size_limit = "Point(225,COORD_MAX)"
							feature_flags  = "TVF_RENDER_HALO|TVF_RENDER_SHADOW|TVF_ENABLE_SHADOW"
							default_color  = "actve"
							font           = "HUGE_BOLD"
							layout_borders = "Rect(0,0,10,0)"
						/>

						<BitmapView name       = "SkullRight"
							bitmap_gfx = "PortraitGUI/little_skull.tga"
							view_flags = "WID_IGNORE_WHEN_HIDDEN"
							layout_borders = "Rect(-12,0,5,0)"
						/>
					</View>



					
				
<!-- === TARGET CONTAINER === -->
				<View view_layout="horizontal">
					<View view_layout="horizontal">
						<BitmapView name                 = "StatBarsContainer"
							view_layout          = "horizontal"
							h_alignment          = "RIGHT"
							view_flags           = "WID_HANDLE_MOUSE"
							layout_borders = "Rect(0,0,-27,0)">
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_minionnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_normalnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_minibossnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_bossnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_gminionnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_gnormalnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_gbossnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_rminionnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_rsubnormalnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_rnormalnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_rbossnew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_playernew.png"/>
							<nocreate:Bitmap name="../../Customized/gfx/frames/v portrait invisible/p_objectnew.png"/>

							<View view_layout="vertical" layout_borders="Rect(0,0,201,0)" h_alignment="RIGHT">
								<ProgressBar name            = "HealthBar"
									orientation     = "right"
									slider_mode     = "clip"
									slide_down_time = "0.1"
									slide_up_time   = "0.0"
									left_margin     = "0"
									right_margin    = "0"
									flash_on_reduce = "false"
									bg_gfx          = "../../Customized/gfx/frames/p_healthbgnew.png"
									fg_gfx          = "../../Customized/gfx/frames/p_healthnew.png"   
									label_font      = "NORMAL"
									layout_borders  = "Rect(0,0,0,0)"
								/>
								<View view_layout="horizontal" >
									<ProgressBar name            = "ManaBar"
										view_flags      = "WID_IGNORE_WHEN_HIDDEN"
										orientation     = "right"
										slider_mode     = "clip"
										slide_down_time = "0.1"
										slide_up_time   = "0.0"
										left_margin     = "0"
										bg_gfx          = ""
										fg_gfx          = ""
										label_font      = "NORMAL"
										layout_borders  = "Rect(0,0,0,10)"
									/>
									<ProgressBar name            = "StaminaBar"
										view_flags      = "WID_IGNORE_WHEN_HIDDEN"
										orientation     = "right"
										slider_mode     = "clip"
										slide_down_time = "0.1"
										slide_up_time   = "0.0"
										left_margin     = "0"
										bg_gfx          = ""
										fg_gfx          = ""
										label_font      = "NORMAL"
										layout_borders  = "Rect(0,0,0,10)"
									/>
								</View>
							</View>
						</BitmapView>
					</View>
				</View>
			</View>
		</View>
<!-- === TARGET'S TARGET NAME&BAR=== -->
<View name           = "TargetContainerView"
			view_layout    = "stacked"
			h_local_alignment="LEFT"
			v_local_alignment="BOTTOM"
			layout_borders = "Rect(27,0,0,-1)">
			<BitmapView name        = "TargetHealthBarBg"
				view_layout = "vertical"
				bitmap_gfx  = "../../Customized/gfx/frames/target_bgnew.png">
				<CharStatBar name            = "TargetHealthBar"
					stat_type       = "health"
					slide_down_time = "0"
					slide_up_time   = "0.0"
					flash_on_reduce = "false"
					bg_gfx          = ""
					fg_gfx          = "../../Customized/gfx/frames/targetnew.png"
					flash_gfx       = ""
				/>
			</BitmapView>
			<TextView name           = "TargetNameView"
				max_size_limit = "Point(160,COORD_MAX)"
				default_color  = "standard_bright"
				font = ""
				feature_flags  = "TVF_RENDER_SHADOW|TVF_RENDER_HALO"
			/>
		</View>

	
	</View>
	<BitmapView name           = "DrunkenBrawlingHaze"
		bitmap_gfx     = "PortraitGUI/portraitsbottom/brawling_drunken_haze.tga"
	/>
</View>
