<!-- Strange UI 2015 -->
<View xmlns:template="template.dtd" name="left_portrait" view_layout="stacked" h_alignment="RIGHT">
  

 
<View view_layout="horizontal" h_local_alignment="center" layout_borders="Rect(0,0,0,50)">
       

<TextView name           = "NameView"
                  
view_alpha = "0"
feature_flags  = "TVF_RENDER_SHADOW|TVF_RENDER_HALO"
                  
default_color  = "active"
                  
font           = "LARGE"
                  
layout_borders = "Rect(0,0,0,0)"
        />
        

<TextView name="LevelView"
 
view_alpha = "0"                 
feature_flags  = "TVF_RENDER_SHADOW|TVF_RENDER_HALO"
                  
default_color  = "active"
                  
font           = "LARGE"
                  
layout_borders = "Rect(5,0,0,0)"
        />
      
</View>
    

<View name="StatBarsContainer" view_layout="stacked" layout_borders="Rect(0,20,0,0)" view_flags="WID_HANDLE_MOUSE">
<ProgressBar name            = "HealthBar"
orientation     = "right"
stat_type       = "health"
slider_mode     = "clip"
slide_down_time = "0.1"
slide_up_time   = "0.1"
left_margin     = "0"
right_margin    = "0"
flash_on_reduce = "false"
bg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/target_bgnew.png"
fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/targetnew.png"
label_font      = "small"
label_color     = "red"
 
/>
 
<TextView name           = "NameView"
                  
feature_flags  = "TVF_RENDER_SHADOW|TVF_RENDER_HALO"
default_color  = "standard_bright"
font           = "LARGE_BOLD"
layout_borders = "Rect(0,0,0,0)"
        /> 

</View> 
</View>    
</View> 





