<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<!-- $Change: 61112 $ (must be within the first 200 characters of the file) -->
<View xmlns:template="template.dtd"
        view_layout="vertical"
        layout_inner_borders="Rect(0,7,0,0)"
  >
  <template:BitmapView template:name="HDivider"
          layout_col_span="3"
          bitmap_gfx="sidebars/horizontal_dividerline.tga"
          max_size_extend="Point(COORD_MAX,-1)"
          _min_size_extend="Point(300,-1)"
          layout_borders="Rect(0,8,15,8)"/>
  <template:BitmapView template:name="VDivider"
          bitmap_gfx="GUIcomponents/list_vertical_dividesr.tga"
          max_size_extend="Point(-1,COORD_MAX)"
          layout_borders="Rect(15,0,15,0)"/>
  <template:TextView feature_flags="TVF_ENABLE_SHADOW|TVF_RENDER_SHADOW|TVF_RENDER_HALO"/>

  <View view_layout="vertical" min_size_extend="Point(260,-1)" layout_inner_borders="Rect(0,10,15,15)" h_local_alignment="LEFT">


    <View view_layout="grid" _max_size_extend="Point(COORD_MAX,-1)" h_local_alignment="LEFT">

      <LayoutRow>
        <TextView value_token="Health"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3  )"/>
        <TextView value_token="Value"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="Health_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="Health_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="HealthRegeneration_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="HealthRegeneration_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="NonCombatHealthRegeneration_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="NonCombatHealthRegeneration_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="HealthTapRating_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="HealthTapRating_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="MagicalHealthTapRating_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="MagicalHealthTapRating_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <BitmapView name="StaminaDivider" template:source="HDivider" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
      </LayoutRow>
      
        <LayoutRow>
          <TextView value_token="Stamina"
                    name="SatminaTitle"
                     view_flags="WID_IGNORE_WHEN_HIDDEN"
                      font="LARGE"
                      default_color="ACTIVE"
                      h_local_alignment="LEFT"
                      layout_borders="Rect(0,0,8,3  )"
                   />
          <TextView value_token="Value"
                    name="StaminaValuesTitle"
                     view_flags="WID_IGNORE_WHEN_HIDDEN"
                      font="LARGE"
                      default_color="ACTIVE"
                      h_local_alignment="LEFT"
                      layout_borders="Rect(0,0,8,3  )"/>
        </LayoutRow>

        <LayoutRow>
          <TextView name="Stamina_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
          <TextView name="Stamina_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
        </LayoutRow>

        <LayoutRow>
          <TextView name="StaminaRegeneration_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
          <TextView name="StaminaRegeneration_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
        </LayoutRow>

        <LayoutRow>
          <TextView name="NonCombatStaminaRegeneration_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
          <TextView name="NonCombatStaminaRegeneration_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
        </LayoutRow>

        <LayoutRow>
          <TextView name="StaminaTapRating_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
          <TextView name="StaminaTapRating_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
        </LayoutRow>

        <LayoutRow>
          <TextView name="MagicalStaminaTapRating_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
          <TextView name="MagicalStaminaTapRating_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )" view_flags="WID_IGNORE_WHEN_HIDDEN"/>
        </LayoutRow>

        <LayoutRow>
          <BitmapView template:source="HDivider"/>
        </LayoutRow>

      <LayoutRow>
        <TextView value_token="Energy"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3  )"
                   />
        <TextView value_token="Value"
                    font="LARGE"
                    default_color="ACTIVE"
                    h_local_alignment="LEFT"
                    layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="EnergyDrainTime_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="EnergyDrainTime_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

      <LayoutRow>
        <TextView name="EnergyRegenTime_label" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
        <TextView name="EnergyRegenTime_value" h_local_alignment="LEFT" layout_borders="Rect(0,0,8,3  )"/>
      </LayoutRow>

    </View>
    <VLayoutSpacer/>
  </View>
</View>
