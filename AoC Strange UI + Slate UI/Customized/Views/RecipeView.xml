<!-- Strange UI 2015 -->
<View view_layout="stacked">
    <BorderView name="PaperBorder" 
				gfx_tl         = "../../Customized/gfx/frames/right_tab_topleft.png"
				gfx_tr         = "../../Customized/gfx/frames/left_tab_topright.png"
				gfx_bl         = "../../Customized/gfx/frames/right_tab_bottomleft.png"
				gfx_br         = "../../Customized/gfx/frames/left_tab_bottomright.png"
				gfx_left       = "../../Customized/gfx/frames/right_tab_left.png"
				gfx_top        = "../../Customized/gfx/frames/left_tab_top.png"
				gfx_right      = "../../Customized/gfx/frames/left_tab_right.png"
				gfx_bottom     = "../../Customized/gfx/frames/left_tab_bottom.png"
				gfx_background = "../../Customized/gfx/frames/bg.png"
				bg_bitmap_borders     = "Rect(20,20,20,20)"
        view_layout="stacked"
        view_flags="BVF_TILE_BACKGROUND">

        <View view_layout="vertical" layout_inner_borders="Rect(10,5,12,10)">
            <View layout_borders="Rect(0,0,-5,0)" view_layout="horizontal">
                <HLayoutSpacer/>
        <Button gfxid_highlight="GUIcomponents/closebuttons/close_white_hover.tga"
        gfxid_pressed="GUIcomponents/closebuttons/close_white_pressed.tga"
        gfxid_raised="GUIcomponents/closebuttons/close_white.tga"
        name="CloseButton"/>
            </View>
            <View layout_borders="Rect(0,0,0,0)" view_layout="horizontal">
                <Button name="LeftArrowButton" gfxid_highlight="Misc/arrow_left_active.tga" gfxid_pressed="Misc/arrow_left_black.tga" gfxid_raised="Misc/arrow_left.tga" layout_borders="Rect(20,0,0,0)"/>
                <TextView name="RecipeName" default_color="active" font="LARGE_bold" value="&lt;localized token=RecipeView_Recipe /&gt;" layout_borders="Rect(25,0,25,0)"/>
                <Button name="RightArrowButton" gfxid_highlight="Misc/arrow_right_active.tga" gfxid_pressed="Misc/arrow_right_black.tga" gfxid_raised="Misc/arrow_right.tga" layout_borders="Rect(0,0,20,0)"/>		
            </View>
            <View name="RecipeLines" view_layout="vertical" h_alignment="CENTER"/>
        </View>
    </BorderView>
</View>
