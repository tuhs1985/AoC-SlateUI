<!-- Strange UI 2015 -->
<View view_layout="vertical" fade_in_time="0.5">
	<BitmapView bitmap_gfx="../../Customized/gfx/death/bg4.png" view_layout="vertical">
		<View layout_borders="Rect(0,0,0,0)" view_layout="stacked">
			<View view_layout="horizontal" layout_borders="Rect(0,0,0,0)" layout_inner_borders="Rect(20,0,20,0)">
				<SideScrollView layout_borders="Rect(0,0,0,0)" name="ListView"/>
				<TextView name="NoRessurectText"
					value="&lt;localized token=ResurrectView_NoResPoints /&gt;"
					layout_borders="Rect(0,0,30,0)"
					min_size_extend="Point(160,60)"
					font="small"
					default_color="active"
					feature_flags="TVF_RENDER_SHADOW|TVF_RENDER_HALO|TVF_MULTILINE|TVF_WORD_WRAP"
					view_flags="WID_IGNORE_WHEN_HIDDEN"/>
			</View>
			<View view_layout="horizontal" layout_inner_borders="Rect(20,50,20,0)">
				<Button gfxid_highlight="Misc/arrow_left_active.tga" 
					gfxid_pressed="Misc/arrow_left_black.tga" 
					gfxid_raised="Misc/arrow_left.tga"
					name="PrevButton"/>
				<HLayoutSpacer/>
				<Button gfxid_highlight="Misc/arrow_right_active.tga" 
					gfxid_pressed="Misc/arrow_right_black.tga" 
					gfxid_raised="Misc/arrow_right.tga"
					name="NextButton"/>
			</View>
		</View>
		<VLayoutSpacer/>
		<Button font="small" label="&lt;localized token=ResurrectView_Resurrect /&gt;" layout_borders="Rect(0,0,0,6)" name="ResurrectButton" template:source="StdButtonPaper"/>
	</BitmapView>
</View>