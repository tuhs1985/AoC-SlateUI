<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<!-- $Change: 392055 $ (must be within the first 200 characters of the file) -->
<!-- Strange UI 2015 -->
<View view_layout="stacked" view_flags="WID_HANDLE_MOUSE" min_size_extend="Point(-1,15)">
	<View name           = "HoverInfoArea"
		view_flags     = "WID_AUTO_HIGHLIGHT"
		view_layout    = "stacked"
		layout_borders = "Rect(0,0,12,0)">
		<View view_layout="stacked" h_alignment="LEFT">
		
		<View view_layout="stacked" layout_borders="Rect(0,0,0,0)" h_alignment="LEFT" v_alignment="TOP">
				<CharStatBar  name            = "HealthBar"
					layout_borders  = "Rect(10,0,0,0)"
					stat_type       = "health"
					orientation     = "right"
					flash_on_reduce = "false"
					bg_gfx          = "../../Customized/gfx/frames/raid_health_bg2.png"
					fg_gfx          = "../../Customized/gfx/frames/raid_health2.png"
					/>
				<TextView name              = "DeadOverlay"
					view_flags        = "WID_DONT_INHERIT_ALPHA"
					font              = "SMALL"
					value_token       = "TeamMemberDead"
					layout_borders    = "Rect(75,0,0,0)"
					h_local_alignment = "CENTER"
				/>
			</View>
			
			<TeamMemberClassView  name= "ClassIconView"
				max_size_limit = "Point(15,15)"
				layout_borders = "Rect(2,2,0,0)"
				/>
			<TextView name            = "NameView"
				font            = "SMALL"
				min_size_extend = "Point(50,-1)"
				max_size_limit  = "Point(100,COORD_MAX)"
				layout_borders  = "Rect(12,0,0,10)"
				feature_flags="TVF_RENDER_SHADOW|TVF_RENDER_HALO"
				/>
		</View>
			
	</View>
	<BuffListView name           = "BuffListView"
	layout_borders = "Rect(0,2,13,0)"
	icon_size      = "Point(15,15)"
	icon_spacing   = "Point(2,2)"
	max_columns    = "200"
	h_local_alignment = "RIGHT"
	filter         = "hostile"
	/>
</View>
