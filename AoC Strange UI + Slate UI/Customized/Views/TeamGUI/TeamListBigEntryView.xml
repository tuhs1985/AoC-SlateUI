<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<!-- $Change: 554999 $ (must be within the first 200 characters of the file) -->
<!-- Strange UI 2015 -->
<View view_layout="horizontal" view_flags="WID_HANDLE_MOUSE" min_size_extend="Point(-1,15)">
	<View name="HoverInfoArea" view_flags="WID_AUTO_HIGHLIGHT" view_layout="vertical" h_alignment="LEFT" layout_borders="Rect(0,0,10,0)">
		<View name="Health" view_layout="stacked" h_alignment="LEFT" v_alignment="TOP">
			<TextView name              = "DeadOverlay"
				view_flags        = "WID_DONT_INHERIT_ALPHA"
				font              = "SMALL"
				value_token       = "TeamMemberDead"
				layout_borders    = "Rect(75,3,0,0)"
				h_local_alignment = "CENTER"
			/>
			
			<View view_layout="horizontal">
				<TeamMemberClassView  name           = "ClassIconView"
					max_size_limit = "Point(12,12)"
					layout_borders = "Rect(0,0,0,-4)"
				/>
				<TextView name            = "NameView"
					font            = "SMALL"
					min_size_extend = "Point(80,-1)"
					max_size_limit  = "Point(80,COORD_MAX)"
					layout_borders  = "Rect(0,3,0,0)"
					feature_flags   = "TVF_ENABLE_ELLIPSIS"
				/>
			</View>
		</View>
			<CharStatBar  name  = "HealthBar"
				layout_borders  = "Rect(0,0,0,1)"
				stat_type       = "health"
				orientation     = "right"
				flash_on_reduce = "false"
				bg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/BG.png"
				fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/health.png"
				/>
		<View name="ManaStamina"  view_layout="stacked" h_alignment="LEFT" v_alignment="TOP" view_flags="WID_IGNORE_WHEN_HIDDEN" layout_borders  = "Rect(0,-1,0,0)">
			<View  view_layout="vertical" h_alignment="LEFT" v_alignment="TOP">
			<CharStatBar  name            = "StaminaBar"
					layout_borders  = "Rect(0,0,0,0)"
					stat_type       = "stamina"
					orientation     = "right"
					flash_on_reduce = "false"
					max_size_extend="Point(132,6)"
					bg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/BGsmall.png"
					fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/staminasmall.png"
				/>
				<CharStatBar  name            = "ManaBar"
					layout_borders  = "Rect(0,-1,0,0)"
					stat_type       = "mana"
					orientation     = "right"
					flash_on_reduce = "false"
					max_size_extend="Point(132,6)"
					bg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/BGsmall.png"
					fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/manasmall.png"
				/>
				
			</View>
			<CharStatBar  name            = "BigStaminaBar"
				layout_borders  = "Rect(0,0,0,0)"
				stat_type       = "stamina"
				orientation     = "right"
				flash_on_reduce = "false"
				max_size_extend="Point(132,12)"
				bg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/BG.png"
				fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/stamina.png"
			/>
		</View>
	<BuffListView name              = "BuffListView"
		v_local_alignment = "TOP"
		layout_borders    = "Rect(2,1,3,0)"
		icon_size         = "Point(15,15)"
		icon_spacing      = "Point(2,2)"
		max_columns       = "8"
		h_local_alignment="RIGHT"
		filter            = "hostile"
	/>
	</View>
</View>
