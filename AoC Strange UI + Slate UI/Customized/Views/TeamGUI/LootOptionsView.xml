<?xml version="1.0" encoding="utf-8" standalone="yes" ?>
<!-- $Change: 392055 $ (must be within the first 200 characters of the file) -->
<View xmlns:template="template.dtd" name="LootOptions" view_layout="vertical" >
  <View name="LootOptionsHeader" />
  <View view_layout="horizontal" >
    <View view_layout="vertical" >
      <View view_layout="horizontal" v_alignment="CENTER" >
        <TextView value             = "&lt;localized token=LootOptions_LootingType /&gt;"
                  width_group       = "LabelGroup"
                  width_group_owner = "LootOptions"
                  font              = "Large"
                  layout_borders    = "Rect(10,0,5,0)"
        />
        <DropdownMenu name              = "LootingTypeDropdown"
                      width_group       = "DropdownGroup"
                      width_group_owner = "LootOptions"
                      layout_borders    = "Rect(0,0,5,0)"
        />
      </View>
      <View view_layout="horizontal" v_alignment="CENTER" >
        <TextView value             = "&lt;localized token=LootOptions_NeedGreed /&gt;"
                  width_group       = "LabelGroup"
                  width_group_owner = "LootOptions"
                  font              = "Large"
                  layout_borders    = "Rect(10,0,5,0)"
        />
        <DropdownMenu name              = "NeedGreedDropdown"
                      width_group       = "DropdownGroup"
                      width_group_owner = "LootOptions"
                      layout_borders    = "Rect(0,0,5,0)"
        />
      </View>
      <View view_layout="horizontal" v_alignment="CENTER" >
        <TextView value             = "&lt;localized token=LootOptions_LootThreshold /&gt;"
                  width_group       = "LabelGroup"
                  width_group_owner = "LootOptions"
                  font              = "Large"
                  layout_borders    = "Rect(10,0,5,0)"
        />
        <DropdownMenu name              = "LootThresholdDropdown"
                      width_group       = "DropdownGroup"
                      width_group_owner = "LootOptions"
                      layout_borders    = "Rect(0,0,5,0)"
        />
      </View>
    </View>
  </View>
  <View name="PersonalOptionsHeader" />
  <View view_layout="horizontal" v_alignment="CENTER" >
    <TextView value             = "&lt;localized token=LootOptions_PassOnLoot /&gt;"
              width_group       = "LabelGroup"
              width_group_owner = "LootOptions"
              font              = "Large"
              layout_borders    = "Rect(10,0,5,0)"
    />
    <DropdownMenu name              = "PassOnLootDropdown"
                  width_group       = "DropdownGroup"
                  width_group_owner = "LootOptions"
                  layout_borders    = "Rect(0,0,5,0)"
    />
  </View>
  <BitmapView bitmap_gfx      = "sidebars/horizontal_dividerline.tga"
              max_size_extend = "Point(COORD_MAX,-1)"
              layout_borders  = "Rect(3,3,3,0)"
  />
  <View view_layout="horizontal">
    <HLayoutSpacer/>
    <Button name              = "OKButton"
            label             = "&lt;localized token=Ok /&gt;"
            width_group       = "Buttons"
            width_group_owner = ":our_parent:"
   template:source="StdButtonPaper" />
    <Button name              = "CancelButton"
            label             = "&lt;localized token=Cancel /&gt;"
            width_group       = "Buttons"
            width_group_owner = ":our_parent:"
  template:source="StdButtonPaper"  />
  </View>
</View>
