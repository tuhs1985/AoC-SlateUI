<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<!-- $Change: 392055 $ (must be within the first 200 characters of the file) -->

<!-- Strange UI 2015 -->
<View xmlns:template="template.dtd" name="left_portrait" view_layout="stacked" h_alignment="RIGHT">
  

<template:ProgressBar template:name="ManaBarShort" 
bg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg.png" 
fg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/mana.png" />
  

<template:ProgressBar template:name="ManaBarLong" 
bg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg.png" 
fg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/mana.png" />
  

<template:ProgressBar template:name="StaminaBarShort" 
bg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg.png" 
fg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/stamina.png" />
  

<template:ProgressBar template:name="StaminaBarLong" 
bg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg.png" 
fg_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/stamina.png" />

  

<View view_layout="vertical" h_alignment="RIGHT">
    
<View view_layout="stacked" h_alignment="LEFT">
      

<View view_layout="vertical" name="StatBarsContainer" view_flags="BMF_USE_CURRENT_SIZE" v_alignment="TOP" h_alignment="LEFT">
        <BitmapView bitmap_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg_top.png"/>
        
<BitmapView bitmap_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg_middle.png"/>
        
<BitmapView bitmap_gfx="../../Customized/gfx/PortraitGUI/floatingportrait/bg_bottom.png"/>
      
</View>
      

<View view_layout="horizontal" h_local_alignment="center" layout_borders="Rect(5,-37,0,0)">
        
<TextView name           = "NameView"
                  
feature_flags  = "TVF_RENDER_SHADOW|TVF_RENDER_HALO"
                  
default_color  = "active"
                  
font           = "LARGE"
                  
layout_borders = "Rect(0,0,0,0)"
        />
        

<TextView name="LevelView"
                  
feature_flags  = "TVF_RENDER_SHADOW|TVF_RENDER_HALO"
                  
default_color  = "active"
                  
font           = "LARGE"
                  
layout_borders = "Rect(5,0,0,0)"
        />
      
</View>
      

<View name="StatBarsContainer" view_layout="vertical" layout_borders="Rect(4,11,0,0)" view_flags="WID_HANDLE_MOUSE">
        <ProgressBar name            = "HealthBar"
                     
orientation     = "right"
                     
slider_mode     = "clip"
                     
slide_down_time = "0.1"
                     
slide_up_time   = "0.0"
                     
left_margin     = "0"
                     
right_margin    = "0"
                     
flash_on_reduce = "false"
                     
bg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/bg.png"
                     
fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/health.png"
                     
label_font      = "NORMAL"
label_color     = "white"
        />
        

<ProgressBar name            = "StaminaBar"
 
view_flags      = "WID_IGNORE_WHEN_HIDDEN|PBF_CLIP_MAX_COST"                    
orientation     = "right"
                     
slider_mode     = "clip"
                     
slide_down_time = "0.1"
                     
slide_up_time   = "0.0"
                     
left_margin     = "0"
                     
bg_gfx          = ""
                     
fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/stamina.png"
                     
label_font      = "NORMAL"                     
label_color     = "white"
        />
        

<ProgressBar name            = "ManaBar"
                     
view_flags      = "WID_IGNORE_WHEN_HIDDEN|PBF_CLIP_MAX_COST"
                     
orientation     = "right"
                     
slider_mode     = "clip"
                     
slide_down_time = "0.1"
                     
slide_up_time   = "0.0"
                     
left_margin     = "0"
                     
bg_gfx          = ""
                     
fg_gfx          = "../../Customized/gfx/PortraitGUI/floatingportrait/mana.png"       
label_font      = "NORMAL"                    
label_color     = "white"
        />
      
</View>
    
</View>
    

<BuffListView name              = "BuffListView"
                  
h_local_alignment = "LEFT"
                  
layout_borders    = "Rect(7,0,0,0)"
                  
icon_size         = "Point(22,22)"
                  
icon_spacing      = "Point(3,3)"
                  
full_size_limit   = "20"
                  
max_columns       = "5"
                  
filter            = "friendly"
    />
  
</View>

</View>

