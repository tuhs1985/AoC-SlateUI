<?xml version="1.0" standalone="yes"?>
<!-- $Change: 392055 $ (must be within the first 200 characters of the file) -->
<View xmlns:template="template.dtd"
        view_layout="stacked"
        name="TabbedWindowRoot"
        view_flags="WID_HANDLE_MOUSE"
        h_alignment        = "STRETCH"
        v_alignment        = "STRETCH"
        resize_tl   = "Point(15,15)"
        resize_tr   = "Point(15,15)"
        resize_bl   = "Point(27,27)"
        resize_br   = "Point(27,27)"

        resize_edge_borders = "Rect(5,0,5,5)"
        resize_edges       = "Rect(10,10,10,27)"
        dragbar_height     = "20"
        minimum_border_size = "Point(142,120)"

        show_sound = "sfx/gui/gui_window_popup.wav"
        hide_sound = "sfx/gui/gui_window_close.wav"
        >
    <BorderView view_layout="stacked" max_size_extend="Point(COORD_MAX,COORD_MAX)"
            layout_borders="Rect(0,0,0,0"
            view_flags           = "BVF_TILE_ALL_BORDERS|BVF_TILE_BACKGROUND"
			  bg_bitmap_borders     = "Rect(20,20,20,20)"
              gfx_tl         = "../../Customized/gfx/frames/right_tab_topleft.png"
              gfx_tr         = "../../Customized/gfx/frames/left_tab_topright.png"
              gfx_bl         = "../../Customized/gfx/frames/right_tab_bottomleft.png"
              gfx_br         = "../../Customized/gfx/frames/left_tab_bottomright.png"
              gfx_left       = "../../Customized/gfx/frames/right_tab_left.png"
              gfx_top        = "../../Customized/gfx/frames/left_tab_top.png"
              gfx_right      = "../../Customized/gfx/frames/left_tab_right.png"
              gfx_bottom     = "../../Customized/gfx/frames/left_tab_bottom.png"
              gfx_background = "../../Customized/gfx/frames/bg.png"/>
    <View view_layout="vertical">
        <View view_layout="horizontal">
            <TabSelector name="WndTabSelector"
                    tab_gfx_selected_left     = "GUIcomponents/Window/windowtab_active_left.tga"
                    tab_gfx_selected_middle   = "GUIcomponents/Window/windowtab_active_center.tga"
                    tab_gfx_selected_right    = "GUIcomponents/Window/windowtab_active_right.tga"

                    tab_gfx_unselected_left     = "GUIcomponents/Window/windowtab_inactive_left.tga"
                    tab_gfx_unselected_middle   = "GUIcomponents/Window/windowtab_inactive_center.tga"
                    tab_gfx_unselected_right    = "GUIcomponents/Window/windowtab_inactive_right.tga"

                    tab_label_borders_selected   = "Rect(15,15,15,3)"
                    tab_label_borders_unselected = "Rect(15,12,15,3)"

                    tab_spacing = "-17.0"
                    layout_borders="Rect(10,0,0,0)"
                    right_margin = "15.0"
                    />
            <HLayoutSpacer layout_weight="0"/>
        </View>
        <VLayoutSpacer/>
    </View>
    <View view_layout="vertical" h_alignment="RIGHT" max_size_extend="Point(COORD_MAX,-1)">
        <Button name="WndCloseButton" layout_borders="Rect(0,10,15,0)"
                max_zoom="1"
                gfxid_raised="GUIcomponents/closebuttons/close_white.tga"
                gfxid_pressed="GUIcomponents/closebuttons/close_white_pressed.tga"
                gfxid_highlight="GUIcomponents/closebuttons/close_white_hover.tga"/>
        <VLayoutSpacer/>
    </View>   
    <ViewSelector name="WndViewSelector" layout_borders ="Rect(9,38,11,12)"/>  
    <View name="WndResizeCorner"
            view_layout="stacked"
            layout_borders="Rect(0,0,13,14)"
            v_alignment="BOTTOM"
            h_alignment="RIGHT"
            max_size_extend="Point(COORD_MAX,COORD_MAX)">            
        <BitmapView bitmap_gfx="GUIcomponents/Window/grabcorner.tga"/>
    </View>
</View>
